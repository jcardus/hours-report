<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Hours Report</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: #f1f3f5;
      color: #212529;
      min-height: 100vh;
      padding: 2rem 1rem;
    }

    .container { max-width: 860px; margin: 0 auto; }

    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
    }

    h1 { font-size: 1.5rem; }

    .lang-switcher { display: flex; gap: 0.375rem; }

    .lang-btn {
      padding: 0.3rem 0.65rem;
      border: 1px solid #ced4da;
      border-radius: 6px;
      background: #fff;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      color: #495057;
    }

    .lang-btn:hover { background: #f1f3f5; }
    .lang-btn.active { background: #343a40; color: #fff; border-color: #343a40; }

    .card {
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 4px rgba(0,0,0,.1);
      padding: 1.25rem 1.5rem;
    }

    #status { color: #6c757d; font-size: 0.9rem; }

    #error {
      display: none;
      background: #fff5f5;
      border: 1px solid #ffc9c9;
      color: #c92a2a;
      border-radius: 10px;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      margin-bottom: 1rem;
    }

    #report { display: none; }

    .report-meta { font-size: 0.85rem; color: #6c757d; margin-bottom: 1rem; }

    table { width: 100%; border-collapse: collapse; }

    th {
      background: #343a40;
      color: #fff;
      text-align: left;
      padding: 0.7rem 1rem;
      font-size: 0.85rem;
      font-weight: 600;
    }

    th:last-child { text-align: right; }

    td { padding: 0.6rem 1rem; border-bottom: 1px solid #dee2e6; font-size: 0.9rem; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f8f9fa; }

    .hours-cell { font-variant-numeric: tabular-nums; font-weight: 600; text-align: right; }
    .no-hours { color: #adb5bd; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1 data-i18n="title"></h1>
      <div class="lang-switcher">
        <button class="lang-btn" data-lang="en">EN</button>
        <button class="lang-btn" data-lang="pt">PT</button>
        <button class="lang-btn" data-lang="es">ES</button>
        <button class="lang-btn" data-lang="fr">FR</button>
      </div>
    </div>

    <div id="error"></div>

    <div class="card" id="status-card">
      <p id="status" data-i18n="loading"></p>
    </div>

    <div id="report" class="card">
      <p class="report-meta" id="report-meta"></p>
      <table>
        <thead>
          <tr>
            <th data-i18n="device"></th>
            <th data-i18n="hours"></th>
          </tr>
        </thead>
        <tbody id="report-body"></tbody>
      </table>
    </div>
  </div>

  <script>
    const translations = {
      en: {
        title: 'Hours Report',
        loading: 'Loading…',
        device: 'Device',
        hours: 'Hours',
        meta: (devices, date) => `${devices} devices · ${date}`,
      },
      pt: {
        title: 'Relatório de Horas',
        loading: 'A carregar…',
        device: 'Dispositivo',
        hours: 'Horas',
        meta: (devices, date) => `${devices} dispositivos · ${date}`,
      },
      es: {
        title: 'Informe de Horas',
        loading: 'Cargando…',
        device: 'Dispositivo',
        hours: 'Horas',
        meta: (devices, date) => `${devices} dispositivos · ${date}`,
      },
      fr: {
        title: 'Rapport d\'Heures',
        loading: 'Chargement…',
        device: 'Appareil',
        hours: 'Heures',
        meta: (devices, date) => `${devices} appareils · ${date}`,
      },
    };

    let currentLang = localStorage.getItem('lang') || navigator.language.slice(0, 2);
    if (!translations[currentLang]) currentLang = 'en';

    function applyLang(lang) {
      currentLang = lang;
      localStorage.setItem('lang', lang);
      const t = translations[lang];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.dataset.i18n;
        if (typeof t[key] === 'string') el.textContent = t[key];
      });
      document.documentElement.lang = lang;
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.lang === lang);
      });
    }

    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => applyLang(btn.dataset.lang));
    });

    applyLang(currentLang);

    // --- data ---

    const statusCard = document.getElementById('status-card');
    const errorEl = document.getElementById('error');
    const reportEl = document.getElementById('report');
    const reportMeta = document.getElementById('report-meta');
    const reportBody = document.getElementById('report-body');

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.style.display = 'block';
      statusCard.style.display = 'none';
    }

    function formatHours(raw) {
      if (raw == null) return null;
      const ms = Number(raw);
      if (isNaN(ms)) return String(raw);
      const totalMins = Math.floor(ms / 60000);
      const hrs = Math.floor(totalMins / 60);
      const mins = totalMins % 60;
      return `${hrs}h ${String(mins).padStart(2, '0')}m`;
    }

    function escHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    async function load() {
      try {
        const [devices, positions] = await Promise.all([
          fetch('/api/devices').then(r => { if (!r.ok) throw new Error(`/api/devices returned ${r.status}`); return r.json(); }),
          fetch('/api/positions').then(r => { if (!r.ok) throw new Error(`/api/positions returned ${r.status}`); return r.json(); }),
        ]);

        const deviceMap = Object.fromEntries(devices.map(d => [d.id, d.name || String(d.id)]));

        const byDevice = {};
        for (const pos of positions) {
          const id = pos.deviceId;
          if (!byDevice[id]) byDevice[id] = { name: deviceMap[id] ?? String(id), positions: [] };
          byDevice[id].positions.push(pos);
        }

        const rows = Object.values(byDevice).sort((a, b) => a.name.localeCompare(b.name));

        reportBody.innerHTML = rows.map(({ name, positions }) => {
          const hoursValues = positions
            .map(p => p.attributes?.hours)
            .filter(v => v != null)
            .map(Number)
            .filter(v => !isNaN(v));

          const maxHours = hoursValues.length ? Math.max(...hoursValues) : null;
          const hoursStr = formatHours(maxHours);

          return `<tr>
            <td>${escHtml(name)}</td>
            <td class="hours-cell">${hoursStr != null ? escHtml(hoursStr) : '<span class="no-hours">—</span>'}</td>
          </tr>`;
        }).join('');

        const t = translations[currentLang];
        reportMeta.textContent = t.meta(rows.length, new Date().toLocaleString(currentLang));
        statusCard.style.display = 'none';
        reportEl.style.display = 'block';
      } catch (err) {
        showError(err.message);
      }
    }

    load();
  </script>
</body>
</html>
